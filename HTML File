<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jacob Johnson</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--ink:#0f0e0c;--ink2:#3a3835;--ink3:#7a7874;--paper:#f9f7f3;--paper2:#f0ede6;--paper3:#e8e3d9;--gold:#b8860b;--gold-light:#f0d98a;--accent:#1a3a2a}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);font-size:16px;line-height:1.6;overflow-x:hidden}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 3rem;background:rgba(249,247,243,0.93);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,0.06)}
.nav-logo{font-family:'Playfair Display',serif;font-weight:700;font-size:1.1rem;color:var(--ink);text-decoration:none}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{font-size:.82rem;font-weight:400;letter-spacing:.08em;text-transform:uppercase;color:var(--ink3);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--ink)}

.hero{display:grid;grid-template-columns:1fr 1fr;align-items:center;min-height:100vh;padding:80px 3rem 0;gap:4rem}
.hero-eyebrow{display:inline-block;font-size:.75rem;font-weight:500;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;border-bottom:1px solid var(--gold-light);padding-bottom:.3rem}
.hero-name{font-family:'Playfair Display',serif;font-size:clamp(3.5rem,6vw,5.5rem);font-weight:900;line-height:1.0;letter-spacing:-.02em;margin-bottom:1.5rem}
.hero-name em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:1.05rem;font-weight:300;color:var(--ink2);max-width:460px;line-height:1.75;margin-bottom:2.5rem}
.hero-ctas{display:flex;gap:1rem;flex-wrap:wrap}
.btn{display:inline-block;padding:.75rem 1.75rem;font-size:.85rem;font-weight:500;letter-spacing:.05em;text-decoration:none;border-radius:3px;transition:all .2s;cursor:pointer;border:none;font-family:'DM Sans',sans-serif}
.btn-primary{background:var(--ink);color:var(--paper)}
.btn-primary:hover{background:var(--ink2)}
.btn-outline{background:transparent;color:var(--ink);border:1.5px solid var(--ink)}
.btn-outline:hover{background:var(--paper3)}

.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem}
.stat-card{background:var(--paper2);border:1px solid var(--paper3);border-radius:8px;padding:1.5rem}
.stat-card.dark{background:var(--accent);border-color:var(--accent);color:#e8f0eb}
.stat-card.dark .stat-label{color:#9bbfa9}
.stat-number{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:700;line-height:1.1;margin-bottom:.3rem}
.stat-label{font-size:.78rem;font-weight:400;color:var(--ink3);letter-spacing:.04em}
.hero-tagline{background:var(--gold);border-radius:8px;padding:1.2rem 1.5rem;font-size:.9rem;font-weight:300;color:#2a1f00;font-style:italic;line-height:1.6}

section{padding:7rem 3rem}
.section-label{display:flex;align-items:center;gap:.8rem;margin-bottom:3.5rem}
.section-label span{font-size:.72rem;letter-spacing:.15em;text-transform:uppercase;color:var(--ink3);font-weight:500}
.section-label::after{content:'';flex:1;height:1px;background:var(--paper3)}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:700;line-height:1.2;margin-bottom:2.5rem}
.section-title em{font-style:italic;color:var(--gold)}

.about{background:var(--paper2)}
.about-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:6rem;align-items:start}
.about-text p{font-size:1.05rem;font-weight:300;line-height:1.85;color:var(--ink2);margin-bottom:1.3rem}
.about-text strong{font-weight:500;color:var(--ink)}
.skills-list{display:flex;flex-direction:column;gap:1.2rem}
.skill-name{font-size:.8rem;font-weight:500;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.5rem;color:var(--ink2)}
.skill-bar{height:2px;background:var(--paper3);border-radius:2px}
.skill-fill{height:2px;background:var(--gold);border-radius:2px}

.work-item{display:grid;grid-template-columns:220px 1fr;gap:4rem;padding:3rem 0;border-top:1px solid var(--paper3);align-items:start}
.work-item:last-child{border-bottom:1px solid var(--paper3)}
.work-company{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;margin-bottom:.3rem}
.work-period{font-size:.78rem;color:var(--ink3);letter-spacing:.05em}
.work-role{font-size:.78rem;font-weight:500;color:var(--gold);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.6rem}
.work-p{font-size:.93rem;font-weight:300;color:var(--ink2);line-height:1.8;margin-bottom:.8rem}
.tags{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.75rem}
.tag{font-size:.72rem;background:var(--paper2);border:1px solid var(--paper3);border-radius:30px;padding:.25rem .7rem;color:var(--ink2)}
.tag.hi{background:rgba(184,134,11,.12);border-color:rgba(184,134,11,.35);color:var(--gold);font-weight:500}

.videos{background:var(--paper2)}
.videos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.vid-card{background:var(--paper);border:1px solid var(--paper3);border-radius:8px;overflow:hidden;text-decoration:none;display:block;transition:transform .2s,box-shadow .2s}
.vid-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(15,14,12,.1)}
.vid-thumb{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:var(--paper3)}
.vid-info{padding:.9rem 1rem}
.vid-title{font-size:.85rem;font-weight:500;color:var(--ink);line-height:1.45;margin-bottom:.25rem}
.vid-meta{font-size:.73rem;color:var(--ink3)}
.vid-channel-card .vid-thumb-inner{width:100%;aspect-ratio:16/9;background:var(--accent);display:flex;align-items:center;justify-content:center}
.vid-channel-card .vid-thumb-inner span{color:#9bbfa9;font-size:.82rem;font-weight:300}

.project{background:var(--accent);color:#e8f0eb}
.project .section-label span{color:#9bbfa9}
.project .section-label::after{background:rgba(255,255,255,.1)}
.project .section-title{color:#e8f0eb}
.project .section-title em{color:var(--gold-light)}
.project-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
.project-body p{font-size:.95rem;font-weight:300;color:#b8cfc0;line-height:1.85;margin-bottom:1rem}
.project-body strong{color:#e8f0eb;font-weight:400}
.tech-tags{display:flex;flex-wrap:wrap;gap:.4rem;margin:1.25rem 0}
.tech-tag{font-size:.73rem;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:4px;padding:.25rem .65rem;color:#c8dfd3}
.feature-list{display:flex;flex-direction:column;gap:.85rem;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:1.75rem}
.feature-row{display:flex;align-items:flex-start;gap:.85rem}
.feature-dot{width:7px;height:7px;border-radius:50%;background:var(--gold-light);margin-top:7px;flex-shrink:0}
.feature-name{font-size:.87rem;font-weight:500;color:#e8f0eb}
.feature-desc{font-size:.78rem;color:#8ab09a;margin-top:2px}

.edu{background:var(--paper2)}
.edu-card{background:var(--paper);border:1px solid var(--paper3);border-radius:12px;padding:2.25rem;display:flex;gap:2rem;align-items:flex-start;max-width:720px}
.edu-badge{width:54px;height:54px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1rem;font-weight:700;color:var(--gold-light);flex-shrink:0}
.edu-name{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;margin-bottom:.15rem}
.edu-deg{font-size:.88rem;color:var(--gold);font-weight:500;margin-bottom:.2rem}
.edu-yr{font-size:.75rem;color:var(--ink3);margin-bottom:.85rem}
.course-tags{display:flex;flex-wrap:wrap;gap:.35rem}
.ctag{font-size:.72rem;background:var(--paper2);border:1px solid var(--paper3);border-radius:4px;padding:.2rem .55rem;color:var(--ink3)}

.contact{text-align:center}
.contact-title{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:900;line-height:1.1;margin-bottom:1rem;max-width:700px;margin-left:auto;margin-right:auto}
.contact-title em{font-style:italic;color:var(--gold)}
.contact-sub{font-size:.95rem;font-weight:300;color:var(--ink3);margin-bottom:2.5rem}
.contact-links{display:flex;gap:.75rem;justify-content:center;flex-wrap:wrap}

footer{background:var(--ink);color:var(--ink3);text-align:center;padding:1.4rem;font-size:.75rem;letter-spacing:.05em}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .65s ease,transform .65s ease}
.reveal.visible{opacity:1;transform:none}

@media(max-width:900px){
  nav{padding:1rem 1.5rem}
  .nav-links{display:none}
  .hero{grid-template-columns:1fr;padding:5.5rem 1.5rem 2rem;min-height:auto;gap:2.5rem}
  section{padding:4rem 1.5rem}
  .about-grid,.project-grid{grid-template-columns:1fr;gap:2.5rem}
  .work-item{grid-template-columns:1fr;gap:.5rem}
  .videos-grid{grid-template-columns:1fr 1fr}
  .edu-card{flex-direction:column;gap:1rem}
}
@media(max-width:560px){.videos-grid{grid-template-columns:1fr}}
</style>
</head>
