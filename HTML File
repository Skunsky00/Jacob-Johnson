<section class="hero">
  <div class="reveal">
    <span class="hero-eyebrow">Finance · Analytics · Product</span>
    <h1 class="hero-name">Jacob<br><em>Johnson</em></h1>
    <p class="hero-sub">Finance graduate who builds things — from full-stack mobile apps to revenue-generating content engines. I combine analytical rigor with a rare ability to actually ship.</p>
    <div class="hero-ctas">
      <a href="#work" class="btn btn-primary">View my work</a>
      <a href="#contact" class="btn btn-outline">Get in touch</a>
    </div>
  </div>
  <div class="reveal" style="transition-delay:.15s">
    <div class="stat-grid">
      <div class="stat-card dark">
        <div class="stat-number">300K+</div>
